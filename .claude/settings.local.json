{
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:vercel.com)",
      "WebFetch(domain:github.com)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(pnpm lf:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm outdated:*)",
      "Bash(find . -type f -name \".*\" | grep -E \"\\\\.\\(json|js|ts|tsx|jsx\\)$\" | head -30)",
      "Bash(pnpm info:*)",
      "Bash(npx next:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm build:*)"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm lf"
          }
        ]
      }
    ]
  }
}
